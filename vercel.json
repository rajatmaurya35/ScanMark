{
    "version": 2,
    "builds": [
        {
            "src": "server.py",
            "use": "@vercel/python"
        },
        {
            "src": "static/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/static/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/server.py"
        }
    ],
    "env": {
        "FLASK_APP": "server.py",
        "FLASK_ENV": "production",
        "FLASK_SECRET_KEY": "your-secret-key-here",
        "DEBUG": "0",
        "MAX_CONTENT_LENGTH": "16777216",
        "UPLOAD_FOLDER": "/tmp",
        "GOOGLE_CLIENT_ID": "784645127656-1ccdef35u935nad2uommpplomn75xoe4g.apps.googleusercontent.com",
        "GOOGLE_REDIRECT_URI": "https://scan-mark-9sht1rc29-rajatmaurya35s-projects.vercel.app/oauth/google/callback"
    }
}
