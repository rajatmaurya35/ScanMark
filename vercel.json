{
    "version": 2,
    "builds": [
        {
            "src": "server.py",
            "use": "@vercel/python"
        },
        {
            "src": "static/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/static/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/server.py"
        }
    ],
    "env": {
        "FLASK_APP": "server.py",
        "FLASK_ENV": "production",
        "FLASK_SECRET_KEY": "your-secret-key-here",
        "DEBUG": "0",
        "MAX_CONTENT_LENGTH": "16777216",
        "UPLOAD_FOLDER": "/tmp"
    }
}
