{
    "version": 2,
    "builds": [
        {
            "src": "server.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/server.py"
        }
    ],
    "env": {
        "FLASK_APP": "server.py",
        "FLASK_ENV": "production",
        "FLASK_SECRET_KEY": "your-secret-key-here",
        "DEBUG": "0",
        "MAX_CONTENT_LENGTH": "16777216",
        "UPLOAD_FOLDER": "/tmp",
        "GOOGLE_CLIENT_ID": "your-client-id-here",
        "GOOGLE_REDIRECT_URI": "https://scan-mark-h0whc1xc2-rajatmaurya35s-projects.vercel.app/oauth2callback"
    }
}
